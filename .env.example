# ============================================
# APP CONFIGURATION
# ============================================
APP_NAME="Sistema Inscripciones UPEA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.render.com

# ============================================
# LOCALE & TIMEZONE
# ============================================
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

# ============================================
# MAINTENANCE
# ============================================
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ============================================
# BCRYPT
# ============================================
BCRYPT_ROUNDS=12

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ============================================
# DATABASE (PostgreSQL - Render)
# ============================================
DB_CONNECTION=pgsql
DB_HOST=<Render-internal-db-host>
DB_PORT=5432
DB_DATABASE=<db-name>
DB_USERNAME=<db-user>
DB_PASSWORD=<db-password>

# ============================================
# SESSION
# ============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================
# BROADCAST & QUEUE
# ============================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ============================================
# CACHE
# ============================================
CACHE_STORE=database
# CACHE_PREFIX=

# ============================================
# REDIS (optional - not required)
# ============================================
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ============================================
# MAIL / BREVO
# ============================================
# MAIL_MAILER ya no se usa para envios transaccionales
MAIL_FROM_ADDRESS="no-reply@upea.bo"
MAIL_FROM_NAME="Sistema Inscripciones UPEA"

# Brevo API - https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# ============================================
# AWS S3 / Cloudflare R2 (storage externo)
# ============================================
# Para S3 (AWS):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Para Cloudflare R2 (alternativa gratuita a S3):
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_URL=
R2_ENDPOINT=
R2_USE_PATH_STYLE_ENDPOINT=true

# ============================================
# JWT
# ============================================
JWT_SECRET=
JWT_TTL=60
JWT_ALGO=HS256

# ============================================
# VITE
# ============================================
VITE_APP_NAME="${APP_NAME}"
